### login
POST {{host}}/system/user/login
Content-Type: application/json

{
    "username": "admin",
    "password": "a1234123"
}
> {%
    client.global.set("token", response.body.data.accessToken);
%}
### create user
POST {{host}}/system/user/create
Content-Type: application/json
Authorization: Bearer {{token}}

{
    "username": "admin",
    "password": "a1234123",
    "nickName": "管理员"
}
### update user
POST {{host}}/system/user/update
Content-Type: application/json
Authorization: Bearer {{token}}

{
    "id": 1,
    "username": "admin"
}
### get user list
GET {{host}}/system/user/list?status=1&page=1&pageSize=10
Authorization: Bearer {{token}}
Content-Type: application/json
### delete user
POST {{host}}/system/user/delete
Content-Type: application/json
Authorization: Bearer {{token}}

{
    "id": 1
}


